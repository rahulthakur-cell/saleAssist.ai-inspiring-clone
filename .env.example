# ============================================================
# SaleAssist.ai Clone — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── General ─────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=SaleAssist
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# Public URL used in customer-facing email links after deployment.
# Example: https://saleassist-web.onrender.com
PUBLIC_APP_URL=http://localhost:3000

# Frontend browser-facing URLs.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_LIVEKIT_WS_URL=ws://localhost:7880

# ─── Database (PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql://saleassist:saleassist_dev_password@localhost:5432/saleassist?schema=public
POSTGRES_USER=saleassist
POSTGRES_PASSWORD=saleassist_dev_password
POSTGRES_DB=saleassist

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth (JWT) ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# ─── Auth (NextAuth) ─────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── Auth (OAuth) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── LiveKit ─────────────────────────────────────────────────
# Use the same LiveKit Cloud project URL here and in NEXT_PUBLIC_LIVEKIT_WS_URL.
# Example: wss://your-project.livekit.cloud
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret_dev_key_change_in_production

# ─── MinIO (S3-compatible Object Storage) ────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev_password
MINIO_BUCKET=saleassist
MINIO_USE_SSL=false
MINIO_CONSOLE_PORT=9001

# ─── Meilisearch ─────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=masterKey_dev_change_in_production

# ─── LiteLLM (AI Gateway) ───────────────────────────────────
LITELLM_URL=http://localhost:4001
LITELLM_API_KEY=sk-litellm-dev-key

# ─── AI Providers (configure in litellm-config.yaml) ────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ─── PostHog (Analytics) ────────────────────────────────────
POSTHOG_API_KEY=phc_dev_key
POSTHOG_HOST=http://localhost:8000

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ─── Coolify (Deployment) ───────────────────────────────────
# Set these in Coolify dashboard, not here
# COOLIFY_FQDN=app.yourdomain.com
